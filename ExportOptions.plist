<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Used by `make upload` ONLY: method app-store-connect + destination
     upload send the archive to App Store Connect and write nothing
     locally. `make export` / `make dmg` use ExportOptionsLocal.plist
     (DOLL-451). The Fastlane release path reads team_id from
     BlackBoxApp/fastlane/Appfile (DOLL-151). When moving the app to a
     new Apple Developer account, update this file,
     ExportOptionsLocal.plist, and Appfile in lockstep. -->
<plist version="1.0">
<dict>
	<key>method</key>
	<string>app-store-connect</string>
	<key>destination</key>
	<string>upload</string>
	<key>teamID</key>
	<string>FB8QBNNT6D</string>
	<key>uploadSymbols</key>
	<true/>
	<key>signingStyle</key>
	<string>automatic</string>
</dict>
</plist>
