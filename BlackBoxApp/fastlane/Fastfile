default_platform(:mac)

# App Store Connect API key authentication (no 2FA needed).
# Generate a key at: https://appstoreconnect.apple.com/access/integrations/api
#
# Local usage (set in .env):
#   ASC_KEY_ID       — Key ID from App Store Connect
#   ASC_ISSUER_ID    — Issuer ID from App Store Connect
#   ASC_KEY_PATH     — Path to the .p8 private key file
#
# CI usage (GitHub Actions secrets):
#   ASC_KEY_ID       — Key ID
#   ASC_ISSUER_ID    — Issuer ID
#   ASC_KEY_CONTENT  — Base64-encoded .p8 key content
def asc_api_key
  key_opts = {
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    in_house: false
  }
  if ENV["ASC_KEY_CONTENT"]
    key_opts[:key_content] = ENV["ASC_KEY_CONTENT"]
  else
    key_opts[:key_filepath] = ENV["ASC_KEY_PATH"]
  end
  app_store_connect_api_key(key_opts)
end

# Resolve the app version `deliver` should target. Without this, deliver
# loops on "Cannot find edit app store version" because uploading a build
# via TestFlight doesn't auto-create the App Store version draft.
#
# Resolution order:
#   1. options[:version]              — when invoked as `fastlane <lane> version:1.2.3`
#   2. ENV["RELEASE_VERSION"]         — set by the release workflow on tag push
#   3. CFBundleShortVersionString in BlackBoxApp/Info.plist  — fallback
def resolve_app_version(options = {})
  version = options[:version] || ENV["RELEASE_VERSION"]
  return version if version && !version.empty?

  plist_path = File.expand_path("../BlackBoxApp/Info.plist", __dir__)
  if File.exist?(plist_path)
    out = `/usr/libexec/PlistBuddy -c "Print :CFBundleShortVersionString" "#{plist_path}" 2>/dev/null`.strip
    return out unless out.empty?
  end
  nil
end

platform :mac do
  desc "Build Rust lib, archive, and upload to TestFlight"
  lane :beta do |options|
    api_key = asc_api_key
    # team_id resolution priority (DOLL-151):
    #   1. ENV["DEVELOPMENT_TEAM"] — CI override via secret
    #   2. Appfile's team_id(...) — single canonical source
    # Removes the prior `|| "FB8QBNNT6D"` literal fallback so a team
    # move only needs editing Appfile (+ ExportOptions.plist).
    team_id = ENV["DEVELOPMENT_TEAM"] ||
              CredentialsManager::AppfileConfig.try_fetch_value(:team_id)

    # Set version from tag (CI) or options
    version = options[:version] || ENV["RELEASE_VERSION"]
    if version
      increment_version_number(version_number: version, xcodeproj: "BlackBoxApp.xcodeproj")
      UI.message("Set marketing version to #{version}")
    end

    # DOLL-154: derive the next build number from Apple's actual state
    # rather than just the committed pbxproj. The committed value drifts
    # every release because increment_build_number mutates pbxproj in
    # memory but never commits the bump back — so the next release would
    # start from the same N as last time and collide with the N+1 already
    # on Apple. Querying TestFlight for the highest build across ALL
    # versions (Apple's CFBundleVersion uniqueness rule is global, not
    # per-marketing-version) removes the local file as a source of truth.
    #
    # Take max(remote, local) + 1 so a fresh-account scenario (Apple has
    # nothing yet but pbxproj has been hand-bumped) doesn't regress.
    latest_remote = latest_testflight_build_number(
      api_key: api_key,
      initial_build_number: 0
    )
    local_committed = get_build_number(xcodeproj: "BlackBoxApp.xcodeproj").to_i
    build_number = [latest_remote, local_committed].max + 1
    increment_build_number(
      build_number: build_number,
      xcodeproj: "BlackBoxApp.xcodeproj"
    )
    UI.message(
      "Build number: #{build_number} " \
      "(max of remote=#{latest_remote}, local=#{local_committed} + 1)"
    )

    # Build Rust static library (skip if already built, e.g. by CI)
    unless ENV["SKIP_RUST_BUILD"]
      sh("cd ../.. && make rust-lib")
    end

    # Build and archive — use ASC API key for automatic provisioning on CI
    xcargs = "DEVELOPMENT_TEAM=#{team_id} ARCHS=arm64"
    if ENV["ASC_KEY_PATH"]
      xcargs += " -allowProvisioningUpdates"
      xcargs += " -authenticationKeyPath '#{ENV["ASC_KEY_PATH"]}'"
      xcargs += " -authenticationKeyID '#{ENV["ASC_KEY_ID"]}'"
      xcargs += " -authenticationKeyIssuerID '#{ENV["ASC_ISSUER_ID"]}'"
    end

    build_app(
      project: "BlackBoxApp.xcodeproj",
      scheme: "BlackBoxApp",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: team_id,
        uploadSymbols: true
      },
      output_directory: "../target/fastlane",
      clean: true,
      xcargs: xcargs
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload metadata and screenshots to App Store Connect"
  #
  # Intentionally narrow scope: this lane syncs *text* metadata
  # (release notes, description, keywords, screenshots). It does NOT
  # touch age ratings or pricing — those have moved through several
  # ASC API schema revisions that fastlane lags behind, so each release
  # would otherwise fail on a new attribute rename. They're set once in
  # the App Store Connect web UI and persist across versions.
  #
  # If age rating / pricing need updating, use the web UI, or pull the
  # current shape with `fastlane fetch_metadata` and regenerate the
  # local config from what Apple currently accepts (DOLL-128/132 style
  # rather than guessing keys).
  lane :metadata do |options|
    api_key = asc_api_key
    deliver_opts = {
      api_key: api_key,
      platform: "osx",
      skip_binary_upload: true,
      force: true,
      # Precheck can't validate IAPs under API-key auth (only Apple ID
      # login), and we have no IAPs anyway. Skip the entire precheck
      # rather than toggle precheck_include_in_app_purchases — fewer
      # moving parts. Submission goes through review at submit_review
      # time, which has its own checks.
      run_precheck_before_submit: false,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots"
      # `price_tier:` removed — the old prices/availableTerritories
      # relationships on `apps` no longer exist; Apple uses
      # appPricePoints + appPriceSchedules now. fastlane's price_tier
      # still hits the dead endpoint and gets a 400.
      #
      # `app_rating_config_path:` removed — the JSON used pre-rename
      # attribute names (SEXUAL_CONTENT_GRAPHIC_NUDITY etc.) that ASC
      # now hard-rejects.
    }
    version = resolve_app_version(options)
    deliver_opts[:app_version] = version if version
    deliver(deliver_opts)
  end

  desc "Download current metadata from App Store Connect"
  lane :fetch_metadata do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      platform: "osx",
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      metadata_path: "./fastlane/metadata"
    )
  end

  desc "Cancel existing review submission (reject current build)"
  lane :cancel_review do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      platform: "osx",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      reject_if_possible: true,
      force: true
    )
  end

  desc "Submit latest build for App Store review (cancels existing submission if needed)"
  lane :submit_review do |options|
    api_key = asc_api_key

    submit_opts = {
      api_key: api_key,
      platform: "osx",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      reject_if_possible: true,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    }

    # Allow specifying build number: fastlane submit_review build:10
    submit_opts[:build_number] = options[:build] if options[:build]

    # Pin the version deliver should submit so we don't pick up an
    # unrelated edit version draft.
    version = resolve_app_version(options)
    submit_opts[:app_version] = version if version

    deliver(submit_opts)
  end

  desc "Check metadata for common rejection reasons"
  lane :check do
    api_key = asc_api_key
    precheck(api_key: api_key, platform: "osx")
  end
end
